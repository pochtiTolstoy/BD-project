digraph partner_source_er {
    graph [
        rankdir=LR,
        bgcolor="white",
        pad=0.35,
        nodesep=0.7,
        ranksep=0.9,
        fontname="Arial",
        label="Фактическая исходная БД партнера из BD2-dump-1/05_source_db_export.sql",
        labelloc=t,
        fontsize=18
    ];

    node [
        shape=plain,
        fontname="Arial"
    ];

    edge [
        fontname="Arial",
        fontsize=11,
        color="#444444",
        arrowsize=0.8
    ];

    customers [
        label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6">
            <TR><TD BGCOLOR="#D9EAF7"><B>customers</B></TD></TR>
            <TR><TD ALIGN="LEFT"><B>cust_id</B> serial PK</TD></TR>
            <TR><TD ALIGN="LEFT">fullname varchar(300)</TD></TR>
            <TR><TD ALIGN="LEFT">birth_dt varchar(50)</TD></TR>
            <TR><TD ALIGN="LEFT">sex varchar(20)</TD></TR>
            <TR><TD ALIGN="LEFT">email varchar(500)</TD></TR>
            <TR><TD ALIGN="LEFT">phone varchar(50)</TD></TR>
            <TR><TD ALIGN="LEFT">phone2 varchar(50)</TD></TR>
            <TR><TD ALIGN="LEFT">inn varchar(30)</TD></TR>
            <TR><TD ALIGN="LEFT">snils varchar(30)</TD></TR>
            <TR><TD ALIGN="LEFT">marital varchar(50)</TD></TR>
            <TR><TD ALIGN="LEFT">loyalty_lvl varchar(50)</TD></TR>
            <TR><TD ALIGN="LEFT">login varchar(150) UNIQUE</TD></TR>
            <TR><TD ALIGN="LEFT">reg_date varchar(50)</TD></TR>
            <TR><TD ALIGN="LEFT">status varchar(30)</TD></TR>
            <TR><TD ALIGN="LEFT">notes text</TD></TR>
        </TABLE>>
    ];

    cust_addresses [
        label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6">
            <TR><TD BGCOLOR="#FCE4D6"><B>cust_addresses</B></TD></TR>
            <TR><TD ALIGN="LEFT"><B>addr_id</B> serial PK</TD></TR>
            <TR><TD ALIGN="LEFT">cust_id integer FK</TD></TR>
            <TR><TD ALIGN="LEFT">addr_type varchar(50)</TD></TR>
            <TR><TD ALIGN="LEFT">address text</TD></TR>
            <TR><TD ALIGN="LEFT">city varchar(100)</TD></TR>
            <TR><TD ALIGN="LEFT">zip_code varchar(20)</TD></TR>
        </TABLE>>
    ];

    cust_docs [
        label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6">
            <TR><TD BGCOLOR="#E2F0D9"><B>cust_docs</B></TD></TR>
            <TR><TD ALIGN="LEFT"><B>doc_id</B> serial PK</TD></TR>
            <TR><TD ALIGN="LEFT">cust_id integer FK</TD></TR>
            <TR><TD ALIGN="LEFT">doc_type varchar(50)</TD></TR>
            <TR><TD ALIGN="LEFT">doc_data text</TD></TR>
        </TABLE>>
    ];

    cust_consents [
        label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6">
            <TR><TD BGCOLOR="#FFF2CC"><B>cust_consents</B></TD></TR>
            <TR><TD ALIGN="LEFT"><B>consent_id</B> serial PK</TD></TR>
            <TR><TD ALIGN="LEFT">cust_id integer FK</TD></TR>
            <TR><TD ALIGN="LEFT">consent_for varchar(100)</TD></TR>
            <TR><TD ALIGN="LEFT">agreed varchar(10)</TD></TR>
            <TR><TD ALIGN="LEFT">dt varchar(50)</TD></TR>
        </TABLE>>
    ];

    cust_extra [
        label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6">
            <TR><TD BGCOLOR="#EADCF8"><B>cust_extra</B></TD></TR>
            <TR><TD ALIGN="LEFT"><B>extra_id</B> serial PK</TD></TR>
            <TR><TD ALIGN="LEFT">cust_id integer FK</TD></TR>
            <TR><TD ALIGN="LEFT">param_name varchar(100)</TD></TR>
            <TR><TD ALIGN="LEFT">param_val text</TD></TR>
        </TABLE>>
    ];

    customers -> cust_addresses [label="1:N  customers.cust_id = cust_addresses.cust_id"];
    customers -> cust_docs [label="1:N  customers.cust_id = cust_docs.cust_id"];
    customers -> cust_consents [label="1:N  customers.cust_id = cust_consents.cust_id"];
    customers -> cust_extra [label="1:N  customers.cust_id = cust_extra.cust_id"];
}
